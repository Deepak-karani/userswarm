# ── UserSwarm environment ─────────────────────────────────────────────
# Copy to .env and fill in. EVERYTHING is optional: with no values set, all
# three sponsor integrations + the LLM run in MOCK mode and the app works
# fully offline. Add a credential to flip that integration to its live path.

# LLM (Anthropic). Leave ANTHROPIC_API_KEY blank => LLM mock mode.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL_FAST=claude-sonnet-4-6
LLM_MODEL_SMART=claude-opus-4-8

# Agentspan (Orkes). Blank => in-process workflow runner (still real & visible).
AGENTSPAN_SERVER_URL=http://localhost:6767

# Arize AX. Both blank => Arize mock (spans/evals logged locally + to console).
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Terac. Blank => synthetic human labels so agreement evals still compute.
TERAC_API_KEY=
# TERAC_BASE_URL=https://api.terac.ai

# Persistence. Blank => SQLite file (backend/userswarm.db). Set for Supabase/Postgres.
DATABASE_URL=

# Frontend -> backend base URL (set in frontend/.env.local).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional force-overrides (1/true to force mock, 0/false to force live):
# LLM_MOCK=
# AGENTSPAN_MOCK=
# ARIZE_MOCK=
# TERAC_MOCK=
# BROWSER_HEADLESS=true
# MAX_BROWSER_ACTIONS=12
